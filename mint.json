{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Kova",
  "logo": {
    "dark": "/logo/kova-logo-white.svg",
    "light": "/logo/kova-logo-black.svg",
    "href": "https://kova.ai"
  },
  "favicon": "/logo/kova-logo-notext-black.svg",
  "colors": {
    "primary": "#0f8f86",
    "light": "#c8e4df",
